# Ten plik jest zachowany jako dokumentacja, ale nie jest potrzebny.
# Aplikacja ma teraz wbudowany serwer HTTPS (certs/cert.pem + certs/key.pem).
#
# Jeśli w przyszłości chcesz wystawić aplikację pod domeną, użyj nginx
# jako reverse proxy przed portem 8443:
#
# server {
#     listen 443 ssl;
#     server_name twoj-host.example.com;
#
#     ssl_certificate     /etc/ssl/certs/cert.pem;
#     ssl_certificate_key /etc/ssl/private/key.pem;
#
#     location / {
#         proxy_pass https://127.0.0.1:8443;
#         proxy_ssl_verify off;   # jeśli backend ma self-signed
#     }
# }
