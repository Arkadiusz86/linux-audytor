# Skopiuj do .env i uzupełnij wartości (NIE commituj .env do gita!)

# Silny losowy token do autoryzacji API (min. 32 znaki)
# Generuj: node -e "const c=require('crypto');console.log(c.randomBytes(32).toString('hex'))"
AUDIT_API_TOKEN=tu-wygeneruj-silny-losowy-token-min-32-znaki

# Środowisko uruchomienia (production / development)
NODE_ENV=production

# Port HTTPS
PORT=8443

# Dozwolony origin (Tu wprowadź swój adres I)
ALLOWED_ORIGIN=https://twoj-host.example.com
